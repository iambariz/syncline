#!/usr/bin/env bash
# Pre-commit gate: identical to CI. Enable once per clone with:
#   git config core.hooksPath .githooks
set -euo pipefail

echo "pre-commit: ruff format --check"
uv run ruff format --check .

echo "pre-commit: ruff check"
uv run ruff check .

echo "pre-commit: mypy"
uv run mypy src

echo "pre-commit: pytest"
uv run pytest -q

echo "pre-commit: all gates green"
